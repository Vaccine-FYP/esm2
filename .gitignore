data/antigenicity/**/*.fasta
data/antigenicity/*.fasta
data/antigenicity/raw/

# ---- python / env ----
__pycache__/
*.pyc
*.pyo
.ipynb_checkpoints/
*.egg-info/
.DS_Store

# ---- logs & bundles ----
nohup.*.log
*.log
log.*.txt
*.tar.gz

# ---- keep small model args pickle (force-include) ----
!models/*.pkl

# ---- mmseqs temp databases & installers ----
evaluation/tmp/
**/tmp/
*.sh.installer
Anaconda3-*.sh
Miniconda3-*.sh
Anaconda*-Linux-*.sh

